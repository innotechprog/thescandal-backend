# Server
PORT=5001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/thescandal

# JWT — replace with a strong random secret (64+ chars)
JWT_SECRET=replace_with_a_strong_random_secret_at_least_64_characters_long
JWT_EXPIRES_IN=8h

# Frontend URL (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:3000,http://127.0.0.1:3000,https://thescandal.co.za,https://www.thescandal.co.za
CORS_ALLOW_ALL=false

# Maximum upload file size in MB
MAX_FILE_SIZE_MB=50
